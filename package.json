{
  "name": "@8ux-co/eelzap-mcp-server",
  "version": "0.3.4",
  "type": "module",
  "description": "Standalone MCP server for the Eel Zap CMS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/8ux-co/eelzap-mcp-server.git"
  },
  "homepage": "https://github.com/8ux-co/eelzap-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/8ux-co/eelzap-mcp-server/issues"
  },
  "bin": {
    "eelzap-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.4.1",
    "smol-toml": "^1.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/node": "^24.6.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.38.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.1.0"
  }
}
